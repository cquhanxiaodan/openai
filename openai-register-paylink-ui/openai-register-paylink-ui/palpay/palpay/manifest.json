{
  "manifest_version": 3,
  "name": "ChatGPT Session Helper",
  "version": "1.9.2",
  "description": "ChatGPT 支付链接生成 + Stripe 自动填写",
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://pay.openai.com/*",
    "https://checkout.stripe.com/*",
    "https://js.stripe.com/*",
    "https://www.paypal.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://pay.openai.com/*",
        "https://checkout.stripe.com/*",
        "https://js.stripe.com/*"
      ],
      "js": [
        "content-stripe.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.paypal.com/checkoutweb/*",
        "https://www.paypal.com/webapps/hermes*",
        "https://www.paypal.com/pay*"
      ],
      "js": [
        "content-paypal.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "key": ""
}
